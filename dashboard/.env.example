# Supabase read access for the dashboard (IAI-241). Copy to .env.local for local dev
# (gitignored), and set the same two vars in Vercel → Project Settings → Environment
# Variables (Production + Preview). Use the ANON / publishable key — never service_role.
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_ANON_KEY=

# Server-side only (Vercel Functions: /api/chat, /api/chats). Set in Vercel → Environment
# Variables (Production + Preview); never exposed to the browser. For local `vercel dev`,
# add them to .env.local.
#
# Ask Intel chat (IAI-265). Models run through OpenRouter, so CHAT_MODEL can be swapped to
# any OpenRouter slug (e.g. openai/gpt-4o, google/gemini-2.5-pro) with no code change.
OPENROUTER_API_KEY=
CHAT_MODEL=anthropic/claude-sonnet-5
# Chat history persistence. The service-role key bypasses RLS — server-only, never client.
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
