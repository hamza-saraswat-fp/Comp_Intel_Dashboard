# Retrieval eval — required keys (copy to evals/.env; never commit .env)

# Anthropic: answering (Sonnet 5), judging (Opus 4.8), chunk headers (Haiku 4.5),
# corpus sizing (count_tokens). Same key the comp_intel_monitor uses.
ANTHROPIC_API_KEY=

# OpenAI: condition C embeddings only (text-embedding-3-small). Conditions A and B
# run without it; condition C will error until this is set.
OPENAI_API_KEY=

# Optional overrides
# EVAL_ANSWER_MODEL=claude-sonnet-5
# EVAL_JUDGE_MODEL=claude-opus-4-8
# EVAL_RAG_K=8
